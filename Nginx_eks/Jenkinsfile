pipeline {
    agent any

    environment {
        AWS_REGION   = "us-east-1"
        CLUSTER_NAME = "eks"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/G1RAAJ/Devops-projects.git'
            }
        }

        stage('Verify Repo Structure') {
            steps {
                sh 'pwd'
                sh 'ls -R'
            }
        }

        stage('Terraform Init & Apply') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-creds'
                ]]) {
                    dir('Nginx_eks/Terraform') {
                        sh '''
                        terraform init
                        terraform validate
                        terraform plan
                        terraform apply -auto-approve
                        '''
                    }
                }
            }
        }

        stage('Configure Kubeconfig & Deploy') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-creds'
                ]]) {
                    sh '''
                    aws eks update-kubeconfig \
                    --region $AWS_REGION \
                    --name $CLUSTER_NAME

                    kubectl get nodes

                    helm upgrade --install nginx ./Nginx_eks/Helm \
                    --namespace default

                    kubectl get pods -o wide
                    kubectl get svc
                    '''
                }
            }
        }
    }

    // ✅ Correct placement
    post {

        success {
            echo "✅ Deployment Successful"
        }

        failure {
            echo "❌ Deployment Failed"
        }

        always {
            cleanWs()
        }
    }
}
