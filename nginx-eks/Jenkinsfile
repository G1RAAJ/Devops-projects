pipeline {
    agent any

    environment {
        AWS_REGION   = "us-east-1"
        CLUSTER_NAME = "myeks"
        ACCOUNT_ID   = "652942059461"
        IMAGE_NAME   = "nginx"
        REPO_URL     = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${IMAGE_NAME}"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/G1RAAJ/Devops-projects.git'
            }
        }

        // 🔥 Run setup ONLY if needed
        stage('Setup (One-Time Check)') {
            steps {
                sh '''
                if ! command -v kubectl > /dev/null; then
                    echo "Running setup..."
                    chmod +x setup.sh
                    sudo bash setup.sh
                else
                    echo "Setup already done, skipping"
                fi
                '''
            }
        }

        stage('Verify Tools') {
            steps {
                sh '''
                git --version
                java -version
                aws --version
                docker --version
                jenkins --version
                kubectl version --client
                eksctl version
                terraform -version
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                docker build -t $IMAGE_NAME:latest .
                '''
            }
        }

        // 🔐 AWS Credentials binding
        stage('Login to ECR') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-creds'
                ]]) {
                    sh '''
                    aws ecr describe-repositories --repository-names $IMAGE_NAME \
                    || aws ecr create-repository --repository-name $IMAGE_NAME

                    aws ecr get-login-password --region $AWS_REGION \
                    | docker login --username AWS \
                    --password-stdin $ACCOUNT_ID.dkr.ecr.$AWS_REGION.amazonaws.com
                    '''
                }
            }
        }

        stage('Push to ECR') {
            steps {
                sh '''
                docker tag $IMAGE_NAME:latest $REPO_URL:latest
                docker push $REPO_URL:latest
                '''
            }
        }

        stage('Terraform Apply (EKS)') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-creds'
                ]]) {
                    dir('Tform') {
                        sh '''
                        terraform init -reconfigure
                        terraform apply -auto-approve
                        '''
                    }
                }
            }
        }

        stage('Configure Kubeconfig') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-creds'
                ]]) {
                    sh '''
                    aws eks update-kubeconfig \
                    --region $AWS_REGION \
                    --name $CLUSTER_NAME
                    '''
                }
            }
        }

        stage('Deploy via Helm') {
            steps {
                sh '''
                helm repo add bitnami https://charts.bitnami.com/bitnami
                helm repo update

                helm upgrade --install nginx bitnami/nginx \
                --set image.repository=$REPO_URL \
                --set image.tag=latest \
                --set service.type=LoadBalancer
                '''
            }
        }

        stage('Verify Deployment') {
            steps {
                sh '''
                kubectl get nodes
                kubectl get pods
                kubectl get svc
                '''
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "✅ Deployment Successful"
        }
        failure {
            echo "❌ Pipeline Failed"
        }
    }
}
